# Django settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (SQLite for MVP - zero cost)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# CORS (frontend URL for production)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# Paystack (get live keys from https://paystack.com when ready)
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here
PAYSTACK_SECRET_KEY=sk_live_your_key_here
PAYSTACK_TEST_MODE=False

# Flutterwave (get live keys from https://flutterwave.com when ready)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-live-your_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK-live-your_key_here
FLUTTERWAVE_TEST_MODE=False

# Static/Media files (for production)
STATIC_ROOT=staticfiles
MEDIA_ROOT=media
